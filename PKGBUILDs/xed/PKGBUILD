# Maintainer: CaramOS <caramos@caramos.org>
# Source: https://github.com/linuxmint/xed
pkgname=xed
pkgver=3.8.5
pkgrel=1
pkgdesc='A small and lightweight text editor. X-Apps project.'
arch=('x86_64')
url='https://github.com/linuxmint/xed'
license=('GPL3')
depends=('gtk3' 'gtksourceview5' 'gspell' 'libpeas')
makedepends=('meson' 'ninja' 'vala' 'itstool' 'glib2-devel')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "xed-$pkgver"
    meson setup build --prefix=/usr --buildtype=release
    ninja -C build
}

package() {
    cd "xed-$pkgver"
    DESTDIR="$pkgdir" ninja -C build install
}
