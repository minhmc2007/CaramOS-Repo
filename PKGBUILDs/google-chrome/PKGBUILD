# Source: AUR — google-chrome
pkgname=google-chrome
pkgver=latest
pkgrel=1
pkgdesc='The popular web browser by Google (stable)'
arch=('x86_64')
url='https://www.google.com/chrome/'
license=('custom:google')
depends=('nss' 'nspr' 'gtk3' 'libxss' 'libappindicator-gtk3' 'libcurl-gnutls')
source=("https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm")
sha256sums=('SKIP')

package() {
    rpm2tar "$srcdir/google-chrome-stable_current_x86_64.rpm" -C "$pkgdir"
}
