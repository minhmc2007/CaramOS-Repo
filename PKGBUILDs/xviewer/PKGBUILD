# Maintainer: CaramOS <caramos@caramos.org>
# Source: https://github.com/linuxmint/xviewer
pkgname=xviewer
pkgver=3.4.7
pkgrel=1
pkgdesc='A simple and sophisticated image viewer. X-Apps project.'
arch=('x86_64')
url='https://github.com/linuxmint/xviewer'
license=('GPL3')
depends=('gtk3' 'libpeas' 'exempi' 'libxapp')
makedepends=('meson' 'ninja' 'vala' 'itstool' 'yelp-tools' 'glib2-devel')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "xviewer-$pkgver"
    meson setup build --prefix=/usr --buildtype=release
    ninja -C build
}

package() {
    cd "xviewer-$pkgver"
    DESTDIR="$pkgdir" ninja -C build install
}
