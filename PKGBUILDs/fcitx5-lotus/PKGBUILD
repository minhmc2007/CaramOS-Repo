# Maintainer: CaramOS <caramos@caramos.org>
# Source: https://github.com/LotusInputMethod/fcitx5-lotus

pkgname=fcitx5-lotus
pkgver=3.2.2
pkgrel=1
pkgdesc='Vietnamese input method engine for Fcitx5 — the lotus you wait for'
arch=('x86_64')
url='https://github.com/LotusInputMethod/fcitx5-lotus'
license=('GPL3')
depends=('fcitx5' 'libime' 'boost-libs')
makedepends=('cmake' 'ninja' 'git' 'boost' 'extra-cmake-modules' 'go')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cmake -B build -G Ninja \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DENABLE_TEST=OFF
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
    install -Dm644 "$srcdir/$pkgname-$pkgver/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
